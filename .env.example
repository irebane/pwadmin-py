# Database
DB_HOST=localhost
DB_USER=pwadmin
DB_PASSWORD=changeme
DB_NAME=pw

# Game server
PASS_TYPE=1
SERVER_IP=0.0.0.0
LAN_IP=127.0.0.1
SERVER_PORT=29400
SERVER_PATH=/home/server/
# logservice's fd_formatlog path (see logservice.conf) — used to recover a
# character when gamedbd's account->role index is missing its entry
FORMATLOG_PATH=/home/logservice/logs/world2.formatlog

# Admin credentials (same format as PHP config)
ADMIN_ID=0
ADMIN_PW=changeme_hashed

# Session keys (copy from PHP config.php $AKey1 / $AKey2)
AKEY1=changeme1
AKEY2=changeme2

# App
SECRET_KEY=generate-with-python-secrets-token-hex-32
APP_PORT=8420

# New player defaults
START_GOLD=0
START_POINT=0
MAX_WEB_POINT=9999
POINT_EXC=1

# Class names (JSON — int id → display name)
PW_CLASSES='{
  "1": "Blademaster",
  "2": "Wizard",
  "3": "Psychic",
  "4": "Venomancer",
  "5": "Barbarian",
  "6": "Assassin",
  "7": "Archer",
  "8": "Cleric",
  "9": "Seeker",
  "10": "Mystic",
  "11": "Stormbringer",
  "12": "Duskblade"
}'

# Zone names (JSON — int id → display name)
GS_ZONES='{
  "1": "Archosaur",
  "2": "Etherblade City"
}'

# Server file paths (JSON — int id → "folder*daemon", copy from PHP $ServerFile)
SERVER_FILES='{
  "1": "logservice*logservice",
  "2": "uniquenamed*uniquenamed",
  "7": "gamed*gamed",
  "9": "gdelivery*gdelivery"
}'
